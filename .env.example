# =============================================================================
# ValueChain AI - Environment Variables Template
# Copy to .env (or .env.local) and fill in actual values. NEVER commit .env files.
# =============================================================================

# ---------- Supabase ----------
# Get from https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Backend only, NEVER expose to frontend
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ---------- LLM ----------
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ---------- Korean Disclosures (DART) ----------
# Get from https://opendart.fss.or.kr (free)
DART_API_KEY=your-dart-api-key

# ---------- US Disclosures (SEC EDGAR) ----------
# No API key needed; just register a User-Agent (email required)
SEC_USER_AGENT=ValueChain AI Research your-email@example.com

# ---------- FX Rates ----------
# Bank of Korea ECOS API key (free): https://ecos.bok.or.kr
ECOS_API_KEY=your-ecos-api-key

# ---------- Frontend ----------
# Public-safe URLs (prefixed with NEXT_PUBLIC_ are exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---------- Deployment ----------
NODE_ENV=development
